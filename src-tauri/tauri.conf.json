{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSAI",
  "version": "../package.json",
  "identifier": "com.julnazz.osai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OSAI",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0a0a0c",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/tmp/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/*"],
    "createUpdaterArtifacts": true,
    "publisher": "Jul.Nazz",
    "copyright": "© 2026 Jul.Nazz",
    "category": "DeveloperTool",
    "shortDescription": "OSAI — your AI co-founder's command deck",
    "longDescription": "OSAI is a calm, agent-first desktop cockpit: chat, terminal, browser, files, and a code editor working together, driven by your installed AI CLIs (claude / codex / opencode).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"],
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kingxjullien14/OSAI/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFMTRGMzE3OTZCREI5QTcKUldTbnViMldGL01VN3BDMGtYY3JNMzYyRWlrWTBZdmNackJiemZUckMzbk9YWnI3Q3BPZXlPS2IK"
    }
  }
}
